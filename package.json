{
  "name": "palette-editor",
  "version": "1.1.0",
  "description": "Generate and edit color palettes in Figma",
  "license": "MIT",
  "scripts": {
    "build": "build-figma-plugin --typecheck --minify",
    "watch": "build-figma-plugin --typecheck --watch",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.{ts,tsx}\""
  },
  "figma-plugin": {
    "id": "1649854703752968667",
    "name": "Palette Editor",
    "editorType": [
      "figma"
    ],
    "documentAccess": "dynamic-page",
    "main": {
      "src": "src/main.ts",
      "handler": "default"
    },
    "ui": "src/ui.tsx",
    "networkAccess": {
      "allowedDomains": [
        "*"
      ],
      "reasoning": "Fetch user-supplied image links to extract colors from them."
    }
  },
  "dependencies": {
    "@create-figma-plugin/ui": "^4",
    "@create-figma-plugin/utilities": "^4",
    "@dnd-kit/core": "^6",
    "@dnd-kit/sortable": "^8",
    "@dnd-kit/utilities": "^3",
    "@floating-ui/dom": "^1.7.6",
    "culori": "*",
    "overlayscrollbars": "^2.16.0",
    "preact": "^10",
    "zundo": "^2",
    "zustand": "^5"
  },
  "devDependencies": {
    "@create-figma-plugin/build": "^4",
    "@create-figma-plugin/tsconfig": "^4",
    "@eslint/js": "^9",
    "@figma/plugin-typings": "*",
    "@types/culori": "^4.0.1",
    "eslint": "^9",
    "eslint-config-prettier": "^9",
    "prettier": "^3",
    "typescript": "^5",
    "typescript-eslint": "^8"
  }
}
